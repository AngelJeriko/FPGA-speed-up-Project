# raw uncompressed vector dumps are large (~125 MB) — keep only the .gz in git.
# generated vectors (regenerated by `make gen` / `make asm`) stay out of git too.
vectors/*.bin
vectors/*.txt
# ...but keep the tiny synthetic clamp firing golden (4 KB; NOT regenerable without re-instrumenting
# bwa-mem2, so it is committed like any captured golden). check_clamp validates against it.
!vectors/clamp_synth.bin
# Synthetic multi-contig index files are regenerable via `bwa-mem2 index vectors/synth.fa`; keep
# only synth.fa / synth.fq / synth.fa.ann in git (the .ann is the contig table the validator loads).
vectors/synth.fa.0123
vectors/synth.fa.pac
vectors/synth.fa.amb
vectors/synth.fa.bwt.2bit.64
test_orch
gen_orch_vectors
gen_asm_vectors
gen_seedcov_vectors
gen_window_vectors
gen_ext_vectors
gen_seedext_vectors
gen_chain_vectors
gen_purge_vectors
gen_read_vectors
gen_accel_vectors
gen_chain2aln_vectors
gen_chaining_extend_vectors
check_rmax
measure_dims
check_band
check_fulldp
check_truedp
dp_dump
test_orch_int
test_orch_full
test_orch_hw
test_orch_inthw
*.o
measure_fetch
test_bns_clamp
check_clamp
